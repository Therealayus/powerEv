PORT=5000
# Local: mongodb://localhost:27017/ev-charging
# Atlas: If you get "querySrv ECONNREFUSED", use the Standard connection string (not SRV):
#   In Atlas: Connect → Connect using MongoDB Compass → copy the mongodb://... string (with host:port list), or use Drivers and switch to Standard. Replace <password> and set database name.
MONGODB_URI=mongodb://localhost:27017/ev-charging
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development

# SMTP – required for verification OTP, password reset, welcome emails
# Gmail: enable 2-Step Verification, then create an App Password at
#   https://myaccount.google.com/apppasswords
# Leave SMTP_USER/SMTP_PASSWORD empty to skip sending (OTP/reset still work; codes only in server logs).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional: create/promote admin when running seed. Set these then run: npm run seed
ADMIN_EMAIL=admin@yopmail.com
ADMIN_PASSWORD=Admin123
