PORT=5000
MONGODB_URI=mongodb://localhost:27017/ev-charging
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development

# SMTP – required for verification OTP, password reset, welcome emails
# Gmail: enable 2-Step Verification, then create an App Password at
#   https://myaccount.google.com/apppasswords
# Leave SMTP_USER/SMTP_PASSWORD empty to skip sending (OTP/reset still work; codes only in server logs).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional: create first admin. Set these then run: node src/scripts/create-admin.js
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password
